# Do not re-run `pnpm install` (and its postinstall) before every `pnpm <script>`.
# On this machine the agent venv is managed separately via uv, and the
# postinstall agent-setup step needs uv on PATH; skipping the pre-run check
# keeps `pnpm dev` / `pnpm typecheck` fast and avoids a spurious failure.
verify-deps-before-run=false
